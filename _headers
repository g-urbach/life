# ============================================================
# Cloudflare Pages — Security Headers
# LifeTold v5.77 | Deploy to repo root alongside index.html
# CSP hashes last auto-patched: deploy-v70
# ============================================================
# PRV-09: Content Security Policy
# SEC-19: HSTS
# SEC-09: CSP / X-Content-Type-Options / X-Frame-Options
#
# IMPORTANT — inline event handlers (onclick=):
#   All onclick= attributes have been migrated to addEventListener()
#   as of v5.74 (PRV-09 Build C complete). 'unsafe-inline' has been
#   removed from script-src. SEC-09 hardening step complete.
#
# HOW TO UPDATE CSP:
#   If you add a new CDN or edge function origin, add it to the
#   relevant -src directive below. Test in browser devtools
#   (Console → CSP violations) before merging.
# ============================================================

/*
  # Strict-Transport-Security — SEC-19
  # Tells browsers to always use HTTPS for this domain.
  # max-age=31536000 = 1 year. includeSubDomains covers all subdomains.
  # preload: submit lifetold.app to hstspreload.org once stable.
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # X-Frame-Options — prevents clickjacking
  X-Frame-Options: DENY

  # X-Content-Type-Options — prevents MIME sniffing
  X-Content-Type-Options: nosniff

  # Referrer-Policy — don't leak URL to third parties
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions-Policy — disable features the app doesn't use
  # microphone is deliberately allowed (memoir dictation feature)
  Permissions-Policy: camera=(), geolocation=(), payment=(), usb=(), microphone=(self)

  # Content-Security-Policy — PRV-09 / SEC-09
  #
  # script-src:
  #   'sha256-oTQ0...' 'sha256-v5AsI...' — hashes for the two remaining inline <script> blocks
  #                                        (app init constants + Peecho injector). Regenerate
  #                                        these hashes if either script block content changes.
  #                                        Browser console will print the new hash on violation.
  #   cdn.jsdelivr.net               — Supabase JS, d3-dtree, DOMPurify
  #   cdnjs.cloudflare.com           — jsPDF, D3, lodash
  #   unpkg.com                      — Supabase fallback CDN
  #   *.cloudflare.com               — Cloudflare email-decode script (cdn-cgi)
  #   *.cloudfront.net               — Peecho Button script (wildcard covers all CF subdomains)
  #   static.cloudflareinsights.com  — Cloudflare Web Analytics beacon (auto-injected by Pages)
  #
  # connect-src:
  #   *.supabase.co                  — database, auth, storage, edge functions
  #   www.peecho.com                 — Peecho hosted checkout
  #   wss://*.supabase.co            — Supabase realtime websocket
  #   https://archive.org            — Internet Archive CC0 music MP3 fetch (redirects to *.archive.org CDN nodes)
  #   *.jsdelivr.net cdnjs.cloudflare.com — sourcemap fetches from CDN scripts (suppresses console noise)
  #
  # manifest-src:
  #   blob:                          — PWA manifest generated as blob: URL by service worker
  #
  # img-src:
  #   'self' data: blob:             — app images, data URIs, generated blobs
  #   *.supabase.co                  — user-uploaded photos served from storage
  #
  # font-src:
  #   fonts.gstatic.com              — Google Fonts (Playfair Display, Lato)
  #
  # style-src:
  #   'self' 'unsafe-inline'         — inline <style> blocks
  #   fonts.googleapis.com           — Google Fonts stylesheet
  #
  # frame-ancestors: 'none' — belt-and-braces with X-Frame-Options
  Content-Security-Policy: default-src 'none'; script-src 'sha256-oTQ0qGVjFKJ4fJWnxik+7NDm/UgYFZGxgt5zvxCVDfY=' 'sha256-47nAvpzXq9AQABWSP45Sv2gAfPcuqOjTXzX7XZ+ZgSU=' 'self' cdn.jsdelivr.net cdnjs.cloudflare.com unpkg.com *.cloudflare.com *.cloudfront.net static.cloudflareinsights.com 'sha256-oTQ0qGVjFKJ4fJWnxik+7NDm/UgYFZGxgt5zvxCVDfY=' 'sha256-v5AsIo9wNDOB0/M1NPd4Ew3vmSnYvDMJaQdGtQ9QA44='; connect-src 'self' *.supabase.co www.peecho.com wss://*.supabase.co https://archive.org https://*.archive.org *.jsdelivr.net cdnjs.cloudflare.com; img-src 'self' data: blob: *.supabase.co; font-src 'self' fonts.gstatic.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; manifest-src blob:; frame-ancestors 'none'; form-action 'self'; base-uri 'self'
