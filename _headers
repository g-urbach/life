# ============================================================
# Cloudflare Pages — Security Headers
# LifeTold v5.02 | Deploy to repo root alongside index.html
# ============================================================
# PRV-09: Content Security Policy
# SEC-19: HSTS
# SEC-09: CSP / X-Content-Type-Options / X-Frame-Options
#
# IMPORTANT — inline event handlers (onclick=):
#   The app currently uses inline onclick= attributes throughout.
#   'unsafe-inline' in script-src is required until those are
#   migrated to addEventListener(). Removing 'unsafe-inline' is
#   a future hardening step tracked in SEC-09.
#
# HOW TO UPDATE CSP:
#   If you add a new CDN or edge function origin, add it to the
#   relevant -src directive below. Test in browser devtools
#   (Console → CSP violations) before merging.
# ============================================================

/*
  # Strict-Transport-Security — SEC-19
  # Tells browsers to always use HTTPS for this domain.
  # max-age=31536000 = 1 year. includeSubDomains covers all subdomains.
  # preload: submit lifetold.app to hstspreload.org once stable.
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # X-Frame-Options — prevents clickjacking
  X-Frame-Options: DENY

  # X-Content-Type-Options — prevents MIME sniffing
  X-Content-Type-Options: nosniff

  # Referrer-Policy — don't leak URL to third parties
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions-Policy — disable features the app doesn't use
  # microphone is deliberately allowed (memoir dictation feature)
  Permissions-Policy: camera=(), geolocation=(), payment=(), usb=(), microphone=(self)

  # Content-Security-Policy — PRV-09 / SEC-09
  #
  # script-src:
  #   'self'                         — the app's own inline scripts
  #   'unsafe-inline'                — required for onclick= handlers (see note above)
  #   cdn.jsdelivr.net               — Supabase JS, d3-dtree, DOMPurify
  #   cdnjs.cloudflare.com           — jsPDF, D3, lodash
  #   unpkg.com                      — Supabase fallback CDN
  #   *.cloudflare.com               — Cloudflare email-decode script (cdn-cgi)
  #   *.cloudfront.net               — Peecho Button script (wildcard covers all CF subdomains)
  #
  # connect-src:
  #   *.supabase.co                  — database, auth, storage, edge functions
  #   www.peecho.com                 — Peecho hosted checkout
  #   wss://*.supabase.co            — Supabase realtime websocket
  #   https://pixabay.com            — Pixabay Music API (background music track lookup)
  #   https://cdn.pixabay.com        — Pixabay audio CDN (MP3 fetch for AudioContext)
  #
  # img-src:
  #   'self' data: blob:             — app images, data URIs, generated blobs
  #   *.supabase.co                  — user-uploaded photos served from storage
  #   cdn.pixabay.com                — Pixabay track artwork (if displayed)
  #
  # font-src:
  #   fonts.gstatic.com              — Google Fonts (Playfair Display, Lato)
  #
  # style-src:
  #   'self' 'unsafe-inline'         — inline <style> blocks
  #   fonts.googleapis.com           — Google Fonts stylesheet
  #
  # frame-ancestors: 'none' — belt-and-braces with X-Frame-Options
  Content-Security-Policy: default-src 'none'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net cdnjs.cloudflare.com unpkg.com *.cloudflare.com *.cloudfront.net; connect-src 'self' *.supabase.co www.peecho.com wss://*.supabase.co https://pixabay.com https://cdn.pixabay.com; img-src 'self' data: blob: *.supabase.co cdn.pixabay.com; font-src 'self' fonts.gstatic.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; frame-ancestors 'none'; form-action 'self'; base-uri 'self'
