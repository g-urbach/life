<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#d4a96e"/>
      <stop offset="100%" style="stop-color:#a07840"/>
    </linearGradient>
    <linearGradient id="shine" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.15"/>
      <stop offset="100%" style="stop-color:#ffffff;stop-opacity:0"/>
    </linearGradient>
  </defs>

  <!-- Background rounded square (maskable safe zone is centre 80%) -->
  <rect width="512" height="512" rx="96" fill="url(#bg)"/>
  <rect width="512" height="512" rx="96" fill="url(#shine)"/>

  <!-- Decorative open book / pages motif at bottom -->
  <ellipse cx="256" cy="380" rx="130" ry="8" fill="#2c2416" opacity="0.15"/>

  <!-- The letter L — large, elegant, serif, italic feel -->
  <!-- Vertical stroke -->
  <rect x="148" y="118" width="44" height="230" rx="8" fill="#faf7f2"/>
  <!-- Horizontal foot -->
  <rect x="148" y="314" width="176" height="44" rx="8" fill="#faf7f2"/>

  <!-- Small italic serif accent top-right of L -->
  <rect x="148" y="118" width="80" height="22" rx="6" fill="#faf7f2" opacity="0.5"/>

  <!-- Wordmark: "LifeTold" small at bottom -->
  <text x="256" y="432"
    font-family="Georgia, serif"
    font-size="46"
    font-weight="400"
    letter-spacing="6"
    fill="#faf7f2"
    text-anchor="middle"
    opacity="0.9">LifeTold</text>
</svg>