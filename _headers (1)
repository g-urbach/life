# ============================================================
# Cloudflare Pages — Security Headers
# LifeTold v4.41 | Deploy to repo root alongside index.html
# ============================================================
# PRV-09: Content Security Policy — FULLY HARDENED v4.41
# SEC-19: HSTS
# SEC-09: CSP / X-Content-Type-Options / X-Frame-Options
#
# v4.41 CHANGE: 'unsafe-inline' removed from script-src.
#   All inline onclick=/oninput=/onchange= handlers have been
#   migrated to addEventListener() (Phase 1: v4.40, Phase 2: v4.41).
#   The browser will now refuse to run any script not loaded from
#   the approved CDN list below, even if injected by an attacker.
#
# HOW TO UPDATE CSP:
#   If you add a new CDN or edge function origin, add it to the
#   relevant -src directive below. Test in browser devtools
#   (Console → CSP violations) before merging.
# ============================================================

/*
  # Strict-Transport-Security — SEC-19
  # Tells browsers to always use HTTPS for this domain.
  # max-age=31536000 = 1 year. includeSubDomains covers all subdomains.
  # preload: submit lifetold.app to hstspreload.org once stable.
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # X-Frame-Options — prevents clickjacking
  X-Frame-Options: DENY

  # X-Content-Type-Options — prevents MIME sniffing
  X-Content-Type-Options: nosniff

  # Referrer-Policy — don't leak URL to third parties
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions-Policy — disable features the app doesn't use
  # microphone is deliberately allowed (memoir dictation feature)
  Permissions-Policy: camera=(), geolocation=(), payment=(), usb=(), microphone=(self)

  # Content-Security-Policy — PRV-09 / SEC-09
  #
  # script-src:
  #   'self'                         — the app's own JS files
  #   cdn.jsdelivr.net               — Supabase JS, d3-dtree, DOMPurify
  #   cdnjs.cloudflare.com           — jsPDF, D3, lodash
  #   unpkg.com                      — Supabase fallback CDN
  #   *.cloudflare.com               — Cloudflare email-decode script (cdn-cgi)
  #   d2bkgfbpbm1ap3.cloudfront.net  — Peecho Button script (dynamic injection)
  #
  #   NOTE: 'unsafe-inline' intentionally removed in v4.41.
  #   All handlers migrated to addEventListener(). Do not re-add.
  #
  # connect-src:
  #   *.supabase.co                  — database, auth, storage, edge functions
  #   www.peecho.com                 — Peecho hosted checkout
  #   wss://*.supabase.co            — Supabase realtime websockets
  #
  # img-src:
  #   'self' data: blob:             — app images, data URIs, generated blobs
  #   *.supabase.co                  — user-uploaded photos served from storage
  #
  # font-src:
  #   fonts.gstatic.com              — Google Fonts (Playfair Display, Lato)
  #
  # style-src:
  #   'self' 'unsafe-inline'         — inline <style> blocks (no migration needed;
  #                                    style injection is lower risk than script)
  #   fonts.googleapis.com           — Google Fonts stylesheet
  #
  # frame-ancestors: 'none' — belt-and-braces with X-Frame-Options
  Content-Security-Policy: default-src 'none'; script-src 'self' cdn.jsdelivr.net cdnjs.cloudflare.com unpkg.com *.cloudflare.com d2bkgfbpbm1ap3.cloudfront.net; connect-src 'self' *.supabase.co www.peecho.com wss://*.supabase.co; img-src 'self' data: blob: *.supabase.co; font-src 'self' fonts.gstatic.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; frame-ancestors 'none'; form-action 'self'; base-uri 'self'
